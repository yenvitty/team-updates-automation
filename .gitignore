# .gitignore for n8n workflow project

# Credentials and secrets
credentials.*
*.secret
*.env
.env.*

# Node modules
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build artifacts
dist/
build/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp
